generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?

  @@map("user")
}

model Exame {
  id         Int      @id @default(autoincrement())
  tipo_exame String
valor      Decimal
  descricao  String
  resultado  String
  data_exame DateTime

  @@map("exame")
}

enum YesNo {
  Login
  No
}

model Tokens {
  id          Int     @id @default(autoincrement())
  token       String
  tipo_token  Role
  revoked     Boolean @default(false)
  expiresAt   DateTime
  usuarioId

  
}
